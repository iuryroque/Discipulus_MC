# Configurações das Imagens Docker (locais)
IMAGE_PREFIX=discipulus
VERSION=1.0.0

# Configurações do Banco de Dados
POSTGRES_DB=discipulus_v1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_muito_segura_aqui_123
POSTGRES_PORT=5433

# Configurações JWT
JWT_SECRET=seu_jwt_secret_muito_seguro_aqui_456
JWT_EXPIRATION=86400000

# Configurações de Portas
BACKEND_PORT=8080
FRONTEND_PORT=80

# URLs (altere para seu domínio)
BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost 